<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – DKD Fresh Express</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="app-wrapper">

    <!-- Sidebar -->
    <nav class="sidebar" id="app-sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">🥬</div>
                <h1>DKD Fresh Express</h1>
            <p>Davao City, Philippines</p>
        </div>

        <div class="sidebar-nav">
            <div class="nav-section-title">Main</div>
            <a href="/Dashboard" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <span class="icon">📊</span> Dashboard
            </a>
            <a href="/PriceList" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PriceList" ? "active" : "")">
                <span class="icon">📋</span> Price List
            </a>
            <a href="/PriceList/Print" class="nav-link">
                <span class="icon">🖨️</span> Print Price List
            </a>

            <div class="nav-section-title">Management</div>
            <a href="/Products" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <span class="icon">📦</span> Products
            </a>
            <a href="/Products/UpdatePrices" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "UpdatePrices" ? "active" : "")">
                <span class="icon">💰</span> Update Prices
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Categories" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")">
                    <span class="icon">🏷️</span> Categories
                </a>
            }

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section-title">Admin</div>
                <a href="/AuditLogs" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AuditLogs" ? "active" : "")">
                    <span class="icon">📝</span> Audit Logs
                </a>
            }
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <strong>@User.Identity?.Name</strong>
                <span class="badge @(User.IsInRole("Admin") ? "badge-admin" : "badge-staff")">
                    @(User.IsInRole("Admin") ? "Admin" : "Staff")
                </span>
            </div>
            <form method="post" action="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline btn-sm" style="width:100%;">🚪 Logout</button>
            </form>
        </div>
    </nav>

    <!-- Overlay (mobile) -->
    <div id="sidebar-overlay"></div>

    <!-- Main content -->
    <div class="main-content">
        <div class="topbar">
            <div style="display:flex;align-items:center;gap:12px;">
                <button class="hamburger" id="hamburger-btn">☰</button>
                <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>
            </div>
            <div style="font-size:12px;color:var(--text-muted);">
                🕐 @DateTime.Now.ToString("MMM dd, yyyy")
            </div>
        </div>

        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-auto-hide">✅ @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-auto-hide">❌ @TempData["Error"]</div>
            }

            @RenderBody()
        </div>
    </div>
</div>

<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
