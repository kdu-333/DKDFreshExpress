<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – DKD Fresh Express</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0d4a1c 0%, #1a6b2f 50%, #2d9047 100%);
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.25);
            padding: 40px 36px;
            width: 100%;
            max-width: 400px;
        }
        .login-logo {
            text-align: center;
            margin-bottom: 28px;
        }
        .login-logo .logo-icon {
            font-size: 48px;
            display: block;
            margin-bottom: 8px;
        }
        .login-logo h1 {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary);
            line-height: 1.3;
        }
        .login-logo p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
        .login-card .form-control { margin-bottom: 14px; padding: 11px 14px; }
        .login-card .btn-primary { width: 100%; padding: 12px; font-size: 15px; margin-top: 4px; }
        .validation-summary-errors ul { padding-left: 18px; }
        .field-validation-error { color: #c62828; font-size: 12px; }
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>
