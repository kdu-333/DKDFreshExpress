@model List<DirectWholesaleSupply.Models.Product>
@{
    ViewData["Title"] = "Products";
    var categories = ViewBag.Categories as List<DirectWholesaleSupply.Models.Category> ?? new();
    Layout = "_Layout";
}

<div class="page-header">
    <h2>&#128230; Products</h2>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        @if (User.IsInRole("Admin"))
        {
            <a href="/Products/Create" class="btn btn-primary">&#10133; Add Product</a>
        }
        <a href="/Products/UpdatePrices" class="btn btn-success">&#128176; Update Prices</a>
    </div>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom:16px;">
    <div class="card-body" style="padding:14px 20px;">
        <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
            <div class="form-group" style="margin:0;min-width:180px;">
                <label class="form-label">Category</label>
                <select name="categoryId" class="form-control" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        string selCatStr = ViewBag.SelectedCategory != null ? ViewBag.SelectedCategory.ToString() : "";
                        if (selCatStr == cat.CategoryID.ToString())
                        {
                            <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                        }
                        else
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group" style="margin:0;flex:1;min-width:200px;">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control" placeholder="Search product name..." value="@ViewBag.Search" />
            </div>
            <button type="submit" class="btn btn-primary" style="margin-bottom:1px;">&#128269; Search</button>
            <a href="/Products" class="btn btn-light" style="margin-bottom:1px;">&#10006; Clear</a>
        </form>
    </div>
</div>

@Html.AntiForgeryToken()

<div class="card">
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Unit</th>
                    <th>Wholesale Price</th>
                    <th>Retail Price</th>
                    <th>Quick Adjust</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    int row = 1;
                }
                @foreach (var p in Model)
                {
                    <tr data-product-row="@p.ProductID">
                        <td style="color:var(--text-muted);font-size:12px;">@row</td>
                        <td><strong>@p.ProductName</strong></td>
                        <td><span style="font-size:12px;color:var(--text-muted);">@p.Category?.CategoryName</span></td>
                        <td>per @p.Unit</td>
                        <td>
                            <span class="wholesale-price price-badge">&#8369;@p.WholesalePrice.ToString("N2")</span>
                        </td>
                        <td>
                            <span class="retail-price price-badge">&#8369;@p.RetailPrice.ToString("N2")</span>
                        </td>
                        <td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <div class="quick-adjust-group">
                                    <button class="btn btn-xs btn-up quick-adjust-btn"
                                            data-product="@p.ProductID" data-amount="1" data-field="both"
                                            title="Increase by 1">
                                        &#9650; +1
                                    </button>
                                    <button class="btn btn-xs btn-down quick-adjust-btn"
                                            data-product="@p.ProductID" data-amount="-1" data-field="both"
                                            title="Decrease by 1">
                                        &#9660; -1
                                    </button>
                                    <button class="btn btn-xs btn-up quick-adjust-btn"
                                            data-product="@p.ProductID" data-amount="5" data-field="both"
                                            title="Increase by 5">
                                        &#9650; +5
                                    </button>
                                    <button class="btn btn-xs btn-down quick-adjust-btn"
                                            data-product="@p.ProductID" data-amount="-5" data-field="both"
                                            title="Decrease by 5">
                                        &#9660; -5
                                    </button>
                                </div>
                            }
                        </td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Inactive</span>
                            }
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                <div style="display:flex;gap:4px;">
                                    <a href="/Products/Edit/@p.ProductID" class="btn btn-xs btn-outline">Edit</a>
                                    <a href="/Products/Delete/@p.ProductID" class="btn btn-xs btn-danger confirm-delete">Del</a>
                                </div>
                            </td>
                        }
                    </tr>
                    row++;
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" style="text-align:center;padding:32px;color:var(--text-muted);">
                            No products found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div style="margin-top:12px;font-size:12px;color:var(--text-muted);">
    Showing @Model.Count product(s)
</div>
