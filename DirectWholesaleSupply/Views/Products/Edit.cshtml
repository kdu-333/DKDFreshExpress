@model DirectWholesaleSupply.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as List<DirectWholesaleSupply.Models.Category> ?? new();
    Layout = "_Layout";
}

<div class="page-header">
    <h2>&#9999;&#65039; Edit Product</h2>
    <a href="/Products" class="btn btn-light">&#8592; Back to Products</a>
</div>

<div class="card" style="max-width:640px;">
    <div class="card-header"><h5>@Model.ProductName</h5></div>
    <div class="card-body">
        <form method="post" action="/Products/Edit">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProductID" value="@Model.ProductID" />

            <div class="form-group">
                <label class="form-label">Category</label>
                <select name="CategoryID" class="form-control">
                    @foreach (var cat in categories)
                    {
                        if (Model.CategoryID == cat.CategoryID)
                        {
                            <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                        }
                        else
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Product Name</label>
                <input type="text" name="ProductName" value="@Model.ProductName" class="form-control" />
            </div>

            <div class="row">
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Unit</label>
                        <select name="Unit" class="form-control">
                            @if (Model.Unit == "kg")
                            {
                                <option value="kg" selected>per kg</option>
                                <option value="pc">per pc</option>
                            }
                            else
                            {
                                <option value="kg">per kg</option>
                                <option value="pc" selected>per pc</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Sort Order</label>
                        <input type="number" name="SortOrder" value="@Model.SortOrder" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Wholesale Price (&#8369;)</label>
                        <input type="number" step="0.01" min="0" name="WholesalePrice" value="@Model.WholesalePrice" class="form-control" />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group">
                        <label class="form-label">Retail Price (&#8369;)</label>
                        <input type="number" step="0.01" min="0" name="RetailPrice" value="@Model.RetailPrice" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Notes</label>
                <input type="text" name="Notes" value="@Model.Notes" class="form-control" />
            </div>

            <div class="form-group">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                    @if (Model.IsActive)
                    {
                        <input type="checkbox" name="IsActive" value="true" checked />
                    }
                    else
                    {
                        <input type="checkbox" name="IsActive" value="true" />
                    }
                    <span class="form-label" style="margin:0;">Active</span>
                </label>
            </div>

            <div style="display:flex;gap:10px;margin-top:8px;">
                <button type="submit" class="btn btn-primary">&#128190; Save Changes</button>
                <a href="/Products" class="btn btn-light">Cancel</a>
            </div>
        </form>
    </div>
</div>
